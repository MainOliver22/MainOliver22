# Database
DATABASE_URL=postgresql://platform_user:platform_pass@localhost:5432/investment_platform

# Redis
REDIS_URL=redis://localhost:6379

# JWT Authentication
JWT_SECRET=change_me_jwt_secret
JWT_REFRESH_SECRET=change_me_jwt_refresh_secret
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# KYC Provider
KYC_PROVIDER=onfido
KYC_API_KEY=
KYC_WEBHOOK_SECRET=

# Web3
WALLETCONNECT_PROJECT_ID=

# Payments
PAYMENT_STRIPE_KEY=
PAYMENT_STRIPE_WEBHOOK_SECRET=

# Encryption (AES-256 key for PII at rest)
ENCRYPTION_KEY=

# Admin Defaults
ADMIN_DEFAULT_EMAIL=admin@example.com
ADMIN_DEFAULT_PASSWORD=change_me

# URLs
APP_URL=http://localhost:4000
FRONTEND_URL=http://localhost:3000

# SMTP / Email
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
