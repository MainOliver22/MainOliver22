# ─── Database ────────────────────────────────────────────────────────────────
# Format: postgresql://<user>:<password>@<host>:<port>/<dbname>
# Local dev default — change user/password/host for staging or production.
# To create the DB locally:
#   createuser -P platform_user        (set password when prompted)
#   createdb -O platform_user investment_platform
DATABASE_URL=postgresql://platform_user:platform_pass@localhost:5432/investment_platform

# ─── Redis ────────────────────────────────────────────────────────────────────
# Local dev default. For production use a managed Redis (e.g. Redis Cloud, Upstash).
REDIS_URL=redis://localhost:6379

# ─── JWT Authentication ───────────────────────────────────────────────────────
# Generated secure random secrets — do NOT reuse these across environments.
# Regenerate at any time with: openssl rand -base64 48
JWT_SECRET=OOgjAtRRywQ6hG04bEzkCG1xLNXBQrkarDPgeDc/xETuUXWZ/7cf0KeRZSUYhN+b
JWT_REFRESH_SECRET=hrqJRB9iMN4gNIamzmGKHWgF09RrbBZ192WGZyu/pb9UzFsrRxgRfUH+GZK4jblq
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─── KYC Provider ─────────────────────────────────────────────────────────────
# Using Onfido. To get your keys:
#   1. Sign up at https://onfido.com and create a Sandbox or Live application.
#   2. Go to Settings → API tokens → copy the token into KYC_API_KEY.
#   3. Go to Settings → Webhooks → create a webhook for your APP_URL/api/kyc/webhook
#      and copy the signing secret into KYC_WEBHOOK_SECRET.
KYC_PROVIDER=onfido
KYC_API_KEY=
KYC_WEBHOOK_SECRET=

# ─── Web3 / WalletConnect ─────────────────────────────────────────────────────
# Only needed if you use WalletConnect in the frontend.
# To get a project ID:
#   1. Go to https://cloud.walletconnect.com and sign in.
#   2. Create a new project and copy the Project ID here.
WALLETCONNECT_PROJECT_ID=

# ─── Payments (Stripe) ────────────────────────────────────────────────────────
# To get your keys:
#   1. Sign in at https://dashboard.stripe.com
#   2. Go to Developers → API keys.
#      - Use sk_test_... for development, sk_live_... for production.
#      Copy the Secret key into PAYMENT_STRIPE_KEY.
#   3. Go to Developers → Webhooks → Add endpoint.
#      Point it to: https://api.qfx-finance.com/api/payments/webhook
#      Select events: payment_intent.succeeded, payment_intent.payment_failed, etc.
#      Copy the Signing secret (whsec_...) into PAYMENT_STRIPE_WEBHOOK_SECRET.
PAYMENT_STRIPE_KEY=
PAYMENT_STRIPE_WEBHOOK_SECRET=

# ─── Encryption ───────────────────────────────────────────────────────────────
# AES-256 key used to encrypt PII at rest. Must be exactly 64 hex characters (32 bytes).
# Generated secure random key — do NOT reuse across environments.
# Regenerate with: openssl rand -hex 32
ENCRYPTION_KEY=23ea4910251c5847fde0862102d674b48e1d0ff0e712f67ab95e89f3c7dff6b8

# ─── Admin Defaults ───────────────────────────────────────────────────────────
# Used to seed the first admin account on first run. Change before deploying.
# Must be a valid email for the initial admin account.
ADMIN_DEFAULT_EMAIL=support@qfx-finance.com
# Min 12 chars, mix of upper/lower/number/symbol required.
ADMIN_DEFAULT_PASSWORD=Fpocvna18153?

# ─── App URLs ─────────────────────────────────────────────────────────────────
# BINANCE_API_URL: public Binance REST API — no key needed for price feeds.
BINANCE_API_URL=https://api.binance.com
# APP_URL: public URL of this backend (used in emails, webhooks, etc.)
APP_URL=https://api.qfx-finance.com
# FRONTEND_URL: public URL of the frontend app (used for CORS and email links)
FRONTEND_URL=https://qfx-finance.com

# ─── Server Port ──────────────────────────────────────────────────────────────
PORT=4000

# ─── SMTP / Email ─────────────────────────────────────────────────────────────
# To get SMTP credentials:
#
# Option A — Gmail (personal / workspace):
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=your.email@gmail.com
#   SMTP_PASS=<App Password>   ← generate at https://myaccount.google.com/apppasswords
#                                 (requires 2-Step Verification enabled)
#
# Option B — SendGrid (recommended for production):
#   Sign up at https://sendgrid.com → Settings → API Keys → Create API key (Mail Send scope)
#   SMTP_HOST=smtp.sendgrid.net
#   SMTP_PORT=587
#   SMTP_USER=apikey
#   SMTP_PASS=<your SendGrid API key>
#
# Option C — Mailgun:
#   Sign up at https://mailgun.com → Sending → Domains → SMTP credentials
#   SMTP_HOST=smtp.mailgun.org
#   SMTP_PORT=587
#   SMTP_USER=postmaster@mg.yourdomain.com
#   SMTP_PASS=<Mailgun SMTP password>
#
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
